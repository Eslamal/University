<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- عنوان الديالوج -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_add_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- اسم المادة -->
        <EditText
            android:id="@+id/et_course_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_bg"
            android:backgroundTint="@color/main_background"
            android:hint="@string/hint_course"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:padding="14dp"
            android:layout_marginBottom="12dp"/>

        <!-- القاعة -->
        <EditText
            android:id="@+id/et_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_bg"
            android:backgroundTint="@color/main_background"
            android:hint="@string/hint_room"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:padding="14dp"
            android:layout_marginBottom="12dp"/>

        <!-- الدكتور -->
        <EditText
            android:id="@+id/et_professor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_bg"
            android:backgroundTint="@color/main_background"
            android:hint="@string/hint_prof"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:padding="14dp"
            android:layout_marginBottom="12dp"/>

        <!-- اليوم والوقت (جنب بعض) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/et_day"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_bg"
                android:backgroundTint="@color/main_background"
                android:hint="@string/hint_day"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:padding="14dp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/et_time"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_bg"
                android:backgroundTint="@color/main_background"
                android:hint="@string/hint_time"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:padding="14dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- زرار الحفظ -->
        <Button
            android:id="@+id/btn_save_lecture"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_save"
            app:backgroundTint="@color/accent_color"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            android:elevation="0dp"
            android:layout_marginBottom="8dp"/>

        <!-- زرار الحذف -->
        <Button
            android:id="@+id/btn_delete_lecture"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_delete"
            app:backgroundTint="@color/red_dark"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            android:elevation="0dp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>